---
import manifest from '../chapters.json';

const { episodeTitles, chapters } = manifest as any;

// Group chapters by episode
const episodes: Record<string, any[]> = {};
for (const ch of chapters) {
  const ep = String(ch.episode);
  if (!episodes[ep]) episodes[ep] = [];
  episodes[ep].push(ch);
}

const epTitles: Record<string, string> = episodeTitles;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Sorathel — Review Drafts</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Georgia', 'Times New Roman', serif;
      background: #faf9f6;
      color: #2c2c2c;
      line-height: 1.6;
    }

    /* Password gate */
    #gate {
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      background: #1a1a2e;
    }
    #gate form {
      text-align: center;
      color: #c8c8d0;
      font-family: system-ui, -apple-system, sans-serif;
    }
    #gate h1 {
      font-family: Georgia, serif;
      font-weight: normal;
      letter-spacing: 0.15em;
      color: #e8e6f0;
      margin-bottom: 0.5rem;
      font-size: 2.5rem;
    }
    #gate .subtitle {
      font-size: 1rem;
      color: #8a8a9a;
      font-style: italic;
      margin-bottom: 2rem;
    }
    #gate input {
      padding: 0.7rem 1.2rem;
      font-size: 16px;
      border: 1px solid #3a3a5e;
      background: #2a2a4e;
      color: #e8e6f0;
      border-radius: 4px;
      width: 220px;
      text-align: center;
    }
    #gate input:focus { outline: none; border-color: #6a6a9e; }
    #gate button {
      margin-left: 0.5rem;
      padding: 0.7rem 1.5rem;
      font-size: 16px;
      background: #4a4a7e;
      color: #e8e6f0;
      border: none;
      border-radius: 4px;
      cursor: pointer;
    }
    #gate button:hover { background: #5a5a8e; }
    #gate .error { color: #c87070; margin-top: 1rem; font-size: 14px; display: none; }

    #site { display: none; }

    .hero {
      background: #1a1a2e;
      color: #c8c8d0;
      padding: 4rem 2rem 3rem;
      text-align: center;
    }
    .hero h1 { font-size: 2.5rem; font-weight: normal; letter-spacing: 0.15em; color: #e8e6f0; margin-bottom: 0.5rem; }
    .hero .subtitle { font-size: 1rem; color: #8a8a9a; font-style: italic; letter-spacing: 0.05em; }
    .hero .season { margin-top: 1rem; font-size: 0.85rem; color: #6b6b7b; font-family: system-ui, -apple-system, sans-serif; }

    .container { max-width: 600px; margin: 0 auto; padding: 2rem; }

    .episode { margin-bottom: 2.5rem; }
    .episode-title {
      font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.15em;
      color: #6b6b7b; font-family: system-ui, -apple-system, sans-serif;
      margin-bottom: 1rem; padding-bottom: 0.5rem; border-bottom: 1px solid #e0ddd6;
    }

    .chapter-list { list-style: none; }
    .chapter-list li { margin-bottom: 0.5rem; }
    .chapter-list a {
      display: block; padding: 0.8rem 1rem; color: #2c2c2c;
      text-decoration: none; border-radius: 4px; transition: background 0.15s;
    }
    .chapter-list a:hover { background: #eeecea; }
    .chapter-list .ch-number {
      font-family: system-ui, -apple-system, sans-serif;
      font-size: 0.75rem; color: #8a8a9a; text-transform: uppercase; letter-spacing: 0.1em;
    }
    .chapter-list .ch-character { font-size: 1.1rem; margin-top: 0.15rem; }

    .note {
      margin-top: 3rem; padding: 1.5rem; background: #f0eee8; border-radius: 6px;
      font-size: 0.85rem; color: #5a5a6a; font-family: system-ui, -apple-system, sans-serif; line-height: 1.6;
    }
    .note strong { color: #3a3a4a; }

    @media (max-width: 600px) {
      .hero { padding: 3rem 1.5rem 2rem; }
      .hero h1 { font-size: 2rem; }
      .container { padding: 1.5rem; }
    }
  </style>
</head>
<body>

<!-- Password Gate -->
<div id="gate">
  <form id="gate-form">
    <h1>SORATHEL</h1>
    <div class="subtitle">The World Cracks Open</div>
    <div>
      <input type="password" id="pw" placeholder="Password" autocomplete="off" />
      <button type="submit">Enter</button>
    </div>
    <div class="error" id="pw-error">Wrong password</div>
  </form>
</div>

<!-- Site (hidden until auth) -->
<div id="site">
  <div class="hero">
    <h1>SORATHEL</h1>
    <div class="subtitle">The World Cracks Open</div>
    <div class="season">Season One — Review Drafts</div>
  </div>

  <div class="container">
    {Object.entries(episodes).map(([epNum, chs]) => (
      <div class="episode">
        <div class="episode-title">
          Episode {epNum} — {epTitles[epNum] || ''}
        </div>
        <ul class="chapter-list">
          {chs.map((ch) => (
            <li>
              <a href={`${import.meta.env.BASE_URL}${ch.slug}/`}>
                <div class="ch-number">Chapter {ch.chapter}</div>
                <div class="ch-character">{ch.character}</div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}

    <div class="note">
      <strong>How to leave comments:</strong> Highlight any passage in a chapter
      and a comment box will appear. Your notes are saved in your browser.
      Use "Copy All to Clipboard" to send them.
    </div>
  </div>
</div>

<script>
  const HASH = '60db0a7a9b7f688adb15d500eaeb5c2c095e4759d28c0981b049e7c9620ac7cf';

  async function sha256(str) {
    const buf = await crypto.subtle.digest('SHA-256', new TextEncoder().encode(str));
    return Array.from(new Uint8Array(buf)).map(b => b.toString(16).padStart(2, '0')).join('');
  }

  if (sessionStorage.getItem('sorathel_auth') === 'true') {
    document.getElementById('gate').style.display = 'none';
    document.getElementById('site').style.display = 'block';
  }

  document.getElementById('gate-form').addEventListener('submit', async (e) => {
    e.preventDefault();
    const pw = document.getElementById('pw').value;
    const hash = await sha256(pw);
    if (hash === HASH) {
      sessionStorage.setItem('sorathel_auth', 'true');
      document.getElementById('gate').style.display = 'none';
      document.getElementById('site').style.display = 'block';
    } else {
      document.getElementById('pw-error').style.display = 'block';
    }
  });
</script>

</body>
</html>
